{
  "languageserver": {
		"dockerfile": {
			"command": "docker-langserver",
			"filetypes": ["dockerfile"],
			"args": ["--stdio"]
		},
		"golang": {
			"command": "gopls",
			"rootPatterns": ["go.mod"],
			"disableWorkspaceFolders": true,
			"filetypes": ["go"]
		},
		"lua": {
			"command": "lua-lsp",
			"filetypes": ["lua"]
		}
  },
	"coc.preferences.formatOnSaveFiletypes": ["javascript", "typescript", "javascriptreact", "typescriptreact", "python", "vue"],
	"diagnostic.virtualText": true,
	"python.analysis.autoSearchPaths": true,
	"python.analysis.extraPaths": ["/Users/jaimeabbariao/Documents/bentobox/repos/bentobox/bentobox"],
	"pyright.enable": true
}
