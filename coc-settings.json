{
  "languageserver": {
		"dockerfile": {
			"command": "docker-langserver",
			"filetypes": ["dockerfile"],
			"args": ["--stdio"]
		},
		"golang": {
			"command": "gopls",
			"rootPatterns": ["go.mod"],
			"disableWorkspaceFolders": true,
			"filetypes": ["go"]
		},
		"lua": {
			"command": "lua-lsp",
			"filetypes": ["lua"]
		}
  },
	"coc.preferences.formatOnSaveFiletypes": ["javascript", "typescript", "javascriptreact", "typescriptreact", "python", "vue"],
	"diagnostic.virtualText": true,
	"python.analysis.autoSearchPaths": true,
  "pyright.enable": true,
  "clangd.path": "/Users/jaimeabbariao/.config/coc/extensions/coc-clangd-data/install/12.0.0/clangd_12.0.0/bin/clangd",
	"rust-analyzer.server.path": "~/.local/bin/rust-analyzer"
}
